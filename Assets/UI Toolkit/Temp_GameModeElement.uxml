<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <Style src="project://database/Assets/UI%20Toolkit/Style/GameModeElement.uss?fileID=7433441132597879392&amp;guid=90e5f13f2b1bb6d4ab37ff9735edb692&amp;type=3#GameModeElement"/>
    <ui:VisualElement name="game-mode-root" picking-mode="Ignore" style="width: 90%; height: 200px; align-self: center; margin-top: 17px; margin-right: 17px; margin-bottom: 17px; margin-left: 17px;">
        <ui:Button class="button" style="flex-grow: 1;">
            <ui:Label text="ここにタイトルが来ます。" name="title-value" picking-mode="Ignore" class="text" style="font-size: 42px; -unity-text-align: middle-left; border-top-left-radius: 6px; border-top-right-radius: 6px; border-bottom-right-radius: 6px; border-bottom-left-radius: 6px;"/>
            <ui:Label text="ここに説明文が来ます。" name="description-value" picking-mode="Ignore" class="text" style="font-size: 32px; -unity-text-align: upper-left; white-space: normal; background-color: rgb(28, 31, 46); border-top-left-radius: 10px; border-top-right-radius: 10px; border-bottom-right-radius: 10px; border-bottom-left-radius: 10px; flex-grow: 1; margin-top: 4px; margin-right: 4px; margin-bottom: 4px; margin-left: 4px; padding-top: 4px; padding-right: 4px; padding-bottom: 4px; padding-left: 4px;"/>
        </ui:Button>
    </ui:VisualElement>
</ui:UXML>
